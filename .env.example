# Postgres (Neon). Used by @overstory/db, api, web.
DATABASE_URL=postgresql://user:pass@host/overstory

# OpenRouter — managed metered LLM (D25). Backend holds the key.
OPENROUTER_API_KEY=
# Optional model overrides (OpenRouter slugs). Defaults: reasoning=anthropic/claude-sonnet-4.6, fast=anthropic/claude-haiku-4.5
OVERSTORY_MODEL_REASONING=
OVERSTORY_MODEL_FAST=

# Better Auth (D26). URL must match the api port (auth handler is mounted on the Hono api).
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001

# Overstory backend — where the CLI persists captures and the MCP server reads (D24/D26).
# OVERSTORY_API_KEY is minted by `pnpm --filter @overstory/api seed` (shown once).
OVERSTORY_API_URL=http://localhost:3001
OVERSTORY_API_KEY=

# GitHub App (D27) — read-only, least-privilege. Private key in KMS, not here in prod.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Ports
PORT=3001

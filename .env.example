# Postgres (Neon). Used by @overstory/db, api, web.
DATABASE_URL=postgresql://user:pass@host/overstory

# OpenRouter — managed metered LLM (D25). Backend holds the key.
OPENROUTER_API_KEY=
# Optional model overrides (OpenRouter slugs). Defaults: reasoning=anthropic/claude-sonnet-4.6, fast=anthropic/claude-haiku-4.5
OVERSTORY_MODEL_REASONING=
OVERSTORY_MODEL_FAST=

# Better Auth (D26). URL must match the api port (auth handler is mounted on the Hono api).
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3001
# Web origin (TanStack Start). Defaults to http://localhost:3000.
WEB_BASE_URL=http://localhost:3000

# Public email/password sign-up. Closed unless set to "true" (unset or any other value = closed).
# D36 makes the dashboard fail closed (a stranger resolves to their own empty org, not the dogfood
# tenant), but flipping this open stays gated on the two-user boundary test. See docs/technical/multi-tenant.md.
OVERSTORY_OPEN_SIGNUP=

# Overstory backend — where the CLI persists captures and the MCP server reads (D24/D26).
# OVERSTORY_API_KEY is minted by `pnpm --filter @overstory/api seed` (shown once).
OVERSTORY_API_URL=http://localhost:3001
OVERSTORY_API_KEY=

# Operator account the seed provisions into the dogfood org (D36) so the human dashboard resolves
# a tenant from the session. Set both to have `seed` create a Better Auth user + member row.
SEED_OPERATOR_EMAIL=
SEED_OPERATOR_PASSWORD=
# SEED_OPERATOR_NAME=Operator

# GitHub App (D27) — read-only, least-privilege. Private key in KMS, not here in prod.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Ports
PORT=3001
